{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "YuanJiAIManJu",
  "version": "0.1.0",
  "identifier": "com.yuanji.ai-manju",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "源极AI漫剧",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: https: blob:; media-src 'self' https: blob:; connect-src https: http://localhost:* https://github.com; style-src 'self' 'unsafe-inline' https:; script-src 'self' 'unsafe-eval'; font-src 'self' data:"
    },
    "withGlobalTauri": true
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/MMKJ555-PNG/AI-CanvasPro/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZBOTU0NEE0RjEwQjQwNDIKUldSQ1FBdnhwRVNWYWpueXAva0xGdkhYT2l3cEVWTEhldkhkSDA2ODZoZUFPaUU1aHpQdHhwSTEK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
