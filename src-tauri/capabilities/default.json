{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "默认权限：允许应用直连任意 API（绕过 WebView CORS）",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "updater:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://*" },
        { "url": "http://*" },
        { "url": "https://*:*" },
        { "url": "http://*:*" }
      ]
    }
  ]
}
